<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Store Dashboard</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f0f2f5; color: #333; }
        .header { background: #1a1a2e; color: white; padding: 20px 40px; display: flex; justify-content: space-between; align-items: center; }
        .header h1 { font-size: 1.5rem; }
        .status { padding: 6px 16px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; }
        .status.healthy { background: #27ae60; }
        .status.unhealthy { background: #e74c3c; }
        .container { max-width: 1200px; margin: 30px auto; padding: 0 20px; }
        .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: white; padding: 24px; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .stat-card h3 { font-size: 0.85rem; color: #888; text-transform: uppercase; margin-bottom: 8px; }
        .stat-card .value { font-size: 2rem; font-weight: 700; color: #1a1a2e; }
        .section { background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 30px; overflow: hidden; }
        .section h2 { padding: 20px 24px; border-bottom: 1px solid #eee; font-size: 1.1rem; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 14px 24px; text-align: left; border-bottom: 1px solid #f0f0f0; }
        th { font-size: 0.8rem; text-transform: uppercase; color: #888; font-weight: 600; }
        .badge { padding: 4px 12px; border-radius: 12px; font-size: 0.8rem; font-weight: 600; }
        .badge.completed { background: #d4edda; color: #155724; }
        .badge.shipped { background: #cce5ff; color: #004085; }
        .badge.processing { background: #fff3cd; color: #856404; }
        .badge.pending { background: #f8d7da; color: #721c24; }
        .tabs { display: flex; gap: 0; border-bottom: 2px solid #eee; padding: 0 24px; }
        .tab { padding: 14px 20px; cursor: pointer; font-weight: 600; color: #888; border-bottom: 2px solid transparent; margin-bottom: -2px; }
        .tab.active { color: #1a1a2e; border-bottom-color: #1a1a2e; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .loading { text-align: center; padding: 40px; color: #888; }
        .error { text-align: center; padding: 40px; color: #e74c3c; }
        .price { font-weight: 600; color: #27ae60; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Store Dashboard</h1>
        <span class="status" id="health-status">Checking...</span>
    </div>

    <div class="container">
        <div class="stats">
            <div class="stat-card">
                <h3>Total Products</h3>
                <div class="value" id="total-products">-</div>
            </div>
            <div class="stat-card">
                <h3>Categories</h3>
                <div class="value" id="total-categories">-</div>
            </div>
            <div class="stat-card">
                <h3>Total Orders</h3>
                <div class="value" id="total-orders">-</div>
            </div>
            <div class="stat-card">
                <h3>Revenue</h3>
                <div class="value" id="total-revenue">-</div>
            </div>
        </div>

        <div class="section">
            <div class="tabs">
                <div class="tab active" data-tab="products">Products</div>
                <div class="tab" data-tab="orders">Orders</div>
                <div class="tab" data-tab="categories">Categories</div>
            </div>

            <div class="tab-content active" id="products">
                <div class="loading">Loading products...</div>
            </div>
            <div class="tab-content" id="orders">
                <div class="loading">Loading orders...</div>
            </div>
            <div class="tab-content" id="categories">
                <div class="loading">Loading categories...</div>
            </div>
        </div>
    </div>

    <script>
        const API = '/api';

        // Tabs
        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById(tab.dataset.tab).classList.add('active');
            });
        });

        async function fetchData(endpoint) {
            const res = await fetch(`${API}/${endpoint}`);
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            return res.json();
        }

        function renderTable(headers, rows) {
            return `<table><thead><tr>${headers.map(h => `<th>${h}</th>`).join('')}</tr></thead><tbody>${rows}</tbody></table>`;
        }

        async function loadHealth() {
            const el = document.getElementById('health-status');
            try {
                const data = await fetchData('health');
                el.textContent = 'API Connected';
                el.className = 'status healthy';
            } catch {
                el.textContent = 'API Disconnected';
                el.className = 'status unhealthy';
            }
        }

        async function loadProducts() {
            const el = document.getElementById('products');
            try {
                const data = await fetchData('products');
                document.getElementById('total-products').textContent = data.length;
                const rows = data.map(p => `<tr>
                    <td>${p.id}</td>
                    <td>${p.name}</td>
                    <td>${p.category_name || '-'}</td>
                    <td class="price">$${parseFloat(p.price).toFixed(2)}</td>
                    <td>${p.stock}</td>
                </tr>`).join('');
                el.innerHTML = renderTable(['ID', 'Name', 'Category', 'Price', 'Stock'], rows);
            } catch (e) {
                el.innerHTML = `<div class="error">Failed to load products: ${e.message}</div>`;
            }
        }

        async function loadCategories() {
            const el = document.getElementById('categories');
            try {
                const data = await fetchData('categories');
                document.getElementById('total-categories').textContent = data.length;
                const rows = data.map(c => `<tr>
                    <td>${c.id}</td>
                    <td>${c.name}</td>
                    <td>${c.description || '-'}</td>
                </tr>`).join('');
                el.innerHTML = renderTable(['ID', 'Name', 'Description'], rows);
            } catch (e) {
                el.innerHTML = `<div class="error">Failed to load categories: ${e.message}</div>`;
            }
        }

        async function loadOrders() {
            const el = document.getElementById('orders');
            try {
                const data = await fetchData('orders');
                document.getElementById('total-orders').textContent = data.length;
                const revenue = data.reduce((sum, o) => sum + parseFloat(o.total), 0);
                document.getElementById('total-revenue').textContent = `$${revenue.toFixed(2)}`;
                const rows = data.map(o => `<tr>
                    <td>${o.id}</td>
                    <td>${o.product_name || '-'}</td>
                    <td>${o.quantity}</td>
                    <td class="price">$${parseFloat(o.total).toFixed(2)}</td>
                    <td><span class="badge ${o.status}">${o.status}</span></td>
                </tr>`).join('');
                el.innerHTML = renderTable(['ID', 'Product', 'Qty', 'Total', 'Status'], rows);
            } catch (e) {
                el.innerHTML = `<div class="error">Failed to load orders: ${e.message}</div>`;
            }
        }

        loadHealth();
        loadProducts();
        loadCategories();
        loadOrders();
    </script>
</body>
</html>
